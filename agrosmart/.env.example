# AgroSmart — Next.js frontend environment variables
# Copy this file to .env.local and fill in the values.
# NEVER commit the filled .env.local to version control.

# ── FastAPI backend URL ────────────────────────────────────────────────────────
# Local dev:   http://localhost:8000
# Production:  https://agrosmart-ai-backend.onrender.com  (your Render URL)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your App → API Keys
# Use LIVE keys for production, TEST keys for development.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key_here

# ── Clerk redirect URLs ────────────────────────────────────────────────────────
# These must match the routes defined in your Next.js app.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# ── Google Maps (optional — not used in current Leaflet implementation) ─────────
# Only required if you switch back to the @vis.gl/react-google-maps adapter.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
