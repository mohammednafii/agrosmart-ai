# AgroSmart — FastAPI backend environment variables
# Copy this file to .env and fill in the values.
# NEVER commit the filled .env to version control.

# ── Clerk JWT verification ─────────────────────────────────────────────────────
# Found in Clerk Dashboard → Your App → API Keys → "Frontend API URL"
# Format: https://<your-instance>.clerk.accounts.dev
CLERK_FRONTEND_API_URL=https://your-instance.clerk.accounts.dev

# ── Clerk Management API (used to sync user profiles from Clerk to local DB) ───
# Found in Clerk Dashboard → Your App → API Keys → "Secret keys"
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key_here

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default — zero config, file created automatically):
DATABASE_URL=sqlite:///./agrosmart.db
# PostgreSQL (recommended for Render production — use Render Postgres add-on):
# DATABASE_URL=postgresql://user:password@host:5432/agrosmart

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev:   CORS_ALLOWED_ORIGINS=http://localhost:3000
# Production:  CORS_ALLOWED_ORIGINS=https://agrosmart-ai.vercel.app
# Both:        CORS_ALLOWED_ORIGINS=http://localhost:3000,https://agrosmart-ai.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000
