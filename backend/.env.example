# AgroSmart — FastAPI backend environment variables
# Copy this file to .env and fill in the values.
# NEVER commit the filled .env to version control.

# ── Clerk JWT verification ─────────────────────────────────────────────────────
# Found in Clerk Dashboard → Your App → API Keys → "Frontend API URL"
# Format: https://<your-instance>.clerk.accounts.dev
CLERK_FRONTEND_API_URL=https://your-instance.clerk.accounts.dev

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default — zero config, file created automatically):
DATABASE_URL=sqlite:///./agrosmart.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/agrosmart

# ── Clerk secret key (used to call Clerk Management API for user sync) ─────────
# Found in Clerk Dashboard → Your App → API Keys → "Secret keys"
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
